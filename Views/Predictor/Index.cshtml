@model List<WorldCup2026.Models.Team>
@{
    ViewData["Title"] = "Tournament Predictor";
    var groupColors = ViewBag.GroupColors as Dictionary<string, string> ?? new Dictionary<string, string>();

    var countryCodes = new Dictionary<string, string> {
        {"Mexico", "mx"}, {"South Africa", "za"}, {"South Korea", "kr"}, {"Czech Republic", "cz"},
        {"Canada", "ca"}, {"Bosnia and Herzegovina", "ba"}, {"Qatar", "qa"}, {"Switzerland", "ch"},
        {"Brazil", "br"}, {"Morocco", "ma"}, {"Haiti", "ht"}, {"Scotland", "gb-sct"},
        {"USA", "us"}, {"Paraguay", "py"}, {"Australia", "au"}, {"Turkey", "tr"},
        {"Germany", "de"}, {"Curacao", "cw"}, {"Ivory Coast", "ci"}, {"Ecuador", "ec"},
        {"Netherlands", "nl"}, {"Japan", "jp"}, {"Sweden", "se"}, {"Tunisia", "tn"},
        {"Spain", "es"}, {"Cape Verde", "cv"}, {"Belgium", "be"}, {"Egypt", "eg"},
        {"Saudi Arabia", "sa"}, {"Uruguay", "uy"}, {"Iran", "ir"}, {"New Zealand", "nz"},
        {"France", "fr"}, {"Senegal", "sn"}, {"Iraq", "iq"}, {"Norway", "no"},
        {"Argentina", "ar"}, {"Algeria", "dz"}, {"Austria", "at"}, {"Jordan", "jo"},
        {"Portugal", "pt"}, {"DR Congo", "cd"}, {"Uzbekistan", "uz"}, {"Colombia", "co"},
        {"England", "gb-eng"}, {"Croatia", "hr"}, {"Ghana", "gh"}, {"Panama", "pa"}
    };

    string GetFlagUrl(string countryName) => countryCodes.ContainsKey(countryName) ? $"https://flagcdn.com/w40/{countryCodes[countryName]}.png" : "https://placehold.co/40x30?text=⚽";
}

<style>
    .custom-header { font-family: 'Chreed-ExtraBold', sans-serif; color: #0052B4; }
</style>

<div class="container mt-4">
    @if (ViewBag.IsFinished == true)
    {
        <h1 class="custom-header text-center mb-5">Tournament Summary</h1>

        <div class="row mb-5 justify-content-center">
            <div class="col-md-3">
                <div class="card p-3 shadow-sm border-0" style="background-color: #f5e0c5; border-bottom: 5px solid #CD7F32;">
                    <h6 class="text-muted text-center">3rd Place</h6>
                    <h5 class="text-center">@ViewBag.Bronze?.Name <img src="@GetFlagUrl(ViewBag.Bronze?.Name)" width="25" class="ms-2" /></h5>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3 shadow-sm border-0" style="background-color: #fff8e1; border-bottom: 5px solid #FFD700;">
                    <h6 class="text-warning text-center fw-bold">CHAMPION</h6>
                    <h5 class="text-center">@ViewBag.Gold?.Name <img src="@GetFlagUrl(ViewBag.Gold?.Name)" width="25" class="ms-2" /></h5>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow-sm border-0" style="background-color: #f8f9fa; border-bottom: 5px solid #C0C0C0;">
                    <h6 class="text-muted text-center">Runner-up</h6>
                    <h5 class="text-center">@ViewBag.Silver?.Name <img src="@GetFlagUrl(ViewBag.Silver?.Name)" width="25" class="ms-2" /></h5>
                </div>
            </div>
        </div>

        <h3 class="custom-header text-center mb-4">Final Group Standings</h3>
        <div class="row">
            @foreach (var group in ((List<WorldCup2026.Models.GroupPrediction>)ViewBag.GroupPredictions).GroupBy(p => p.Team.GroupLetter))
            {
                <div class="col-md-3 mb-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header text-white fw-bold" style="background-color: @(groupColors.ContainsKey(group.Key) ? groupColors[group.Key] : "#6c757d");">
                            Group @group.Key
                        </div>
                        <ul class="list-group list-group-flush">
                            @foreach (var team in group.OrderBy(x => x.PredictedPosition))
                            {
                                <li class="list-group-item">
                                    @team.PredictedPosition. @team.Team.Name 
                                    <img src="@GetFlagUrl(team.Team.Name)" width="20" class="ms-2" />
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-5">
            <a asp-action="Reset" class="btn btn-danger btn-lg px-5">Start New Tournament</a>
        </div>
    }
    else
    {
        <h1 class="custom-header text-center mb-5">Predict the Groups</h1>
        <form id="predictorForm" asp-action="SavePredictions" method="post">
            <input type="hidden" name="groupOrders" id="groupOrders" />
            
            <div class="row">
                @foreach (var group in Model.GroupBy(t => t.GroupLetter))
                {
                    <div class="col-md-3 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-header text-white fw-bold" style="background-color: @(groupColors.ContainsKey(group.Key) ? groupColors[group.Key] : "#6c757d");">
                                Group @group.Key
                            </div>
                            <div class="card-body p-2" id="group-@group.Key" data-group="@group.Key">
                                @foreach (var team in group)
                                {
                                    <div class="list-group-item border mb-1 p-2 rounded cursor-pointer" data-id="@team.Id">
                                        @team.Name <img src="@GetFlagUrl(team.Name)" width="25" class="ms-2" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
            
            <div class="text-center mt-4">
                <button type="button" class="btn btn-primary btn-lg px-5" onclick="submitPredictions()">Save & Next</button>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    <script>
        document.querySelectorAll('.card-body').forEach(el => {
            new Sortable(el, { animation: 150 });
        });

        function submitPredictions() {
            let data = {};
            document.querySelectorAll('[data-group]').forEach(groupEl => {
                let groupId = groupEl.getAttribute('data-group');
                let teamIds = Array.from(groupEl.querySelectorAll('[data-id]')).map(el => el.getAttribute('data-id'));
                data[groupId] = teamIds.join(',');
            });
            document.getElementById('groupOrders').value = JSON.stringify(data);
            document.getElementById('predictorForm').submit();
        }
    </script>
}