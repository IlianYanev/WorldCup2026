@model IEnumerable<WorldCup2026.Models.Match>

@{
    ViewData["Title"] = "Match Schedule";
    
    var countryCodes = new Dictionary<string, string>
    {
        {"Mexico", "mx"}, {"South Africa", "za"}, {"South Korea", "kr"}, {"Czech Republic", "cz"},
        {"Canada", "ca"}, {"Bosnia and Herzegovina", "ba"}, {"Qatar", "qa"}, {"Switzerland", "ch"},
        {"Brazil", "br"}, {"Morocco", "ma"}, {"Haiti", "ht"}, {"Scotland", "gb-sct"},
        {"USA", "us"}, {"Paraguay", "py"}, {"Australia", "au"}, {"Turkey", "tr"},
        {"Germany", "de"}, {"Curacao", "cw"}, {"Ivory Coast", "ci"}, {"Ecuador", "ec"},
        {"Netherlands", "nl"}, {"Japan", "jp"}, {"Sweden", "se"}, {"Tunisia", "tn"},
        {"Spain", "es"}, {"Cape Verde", "cv"}, {"Belgium", "be"}, {"Egypt", "eg"},
        {"Saudi Arabia", "sa"}, {"Uruguay", "uy"}, {"Iran", "ir"}, {"New Zealand", "nz"},
        {"France", "fr"}, {"Senegal", "sn"}, {"Iraq", "iq"}, {"Norway", "no"},
        {"Argentina", "ar"}, {"Algeria", "dz"}, {"Austria", "at"}, {"Jordan", "jo"},
        {"Portugal", "pt"}, {"DR Congo", "cd"}, {"Uzbekistan", "uz"}, {"Colombia", "co"},
        {"England", "gb-eng"}, {"Croatia", "hr"}, {"Ghana", "gh"}, {"Panama", "pa"}
    };

    var groupColors = new Dictionary<string, string>
    {
        {"A", "#6A0dad"}, {"B", "#0052B4"}, {"C", "#00B2A9"}, {"D", "#FF4500"},
        {"E", "#007A33"}, {"F", "#E10600"}, {"G", "#9EFD38"}, {"H", "#FF1493"},
        {"I", "#38B6FF"}, {"J", "#8B0000"}, {"K", "#FFA07A"}, {"L", "#111111"}  
    };

    string GetFlagUrl(string countryName) => countryCodes.ContainsKey(countryName) ? $"https://flagcdn.com/w40/{countryCodes[countryName]}.png" : "https://placehold.co/40x30?text=⚽";
    string GetGroupColor(string groupLetter) => groupColors.ContainsKey(groupLetter) ? groupColors[groupLetter] : "#212529";
    string GetTextColor(string groupLetter) => (groupLetter == "G" || groupLetter == "K") ? "#111111" : "#FFFFFF";
}

<div class="container mt-4">
    <h1 class="text-center mb-5 fw-bold page-title">FIFA World Cup 2026</h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">No matches found in the schedule.</div>
    }
    else
    {
        var groupedMatches = Model.GroupBy(m => m.KickOffTime.Date);

        foreach (var dayGroup in groupedMatches)
        {
            <div class="row mt-5 mb-3">
                <div class="col-12">
                    <h3 class="day-header pb-2 fw-bold fs-4">
                        📅 @dayGroup.Key.ToString("dddd, dd.MM.yyyy")
                    </h3>
                </div>
            </div>

            <div class="row">
                @foreach (var match in dayGroup)
                {
                    var bgColor = GetGroupColor(match.HomeTeam.GroupLetter);
                    var textColor = GetTextColor(match.HomeTeam.GroupLetter);

                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 shadow-sm match-card border-0 bg-white rounded-3 overflow-hidden">
                            
                            <div class="card-header d-flex justify-content-between align-items-center border-0 px-3 py-2" 
                                 style="background-color: @bgColor; color: @textColor;">
                                <span class="fw-bold">Group @match.HomeTeam.GroupLetter</span>
                                <span class="badge" style="background-color: rgba(255,255,255,0.2); color: @textColor;">
                                    @match.KickOffTime.ToString("HH:mm")
                                </span>
                            </div>

                            <div class="card-body d-flex flex-column justify-content-center px-3 py-3">
                                
                                <div class="d-flex justify-content-between align-items-center my-2">
                                    <div class="d-flex align-items-center">
                                        <img src="@GetFlagUrl(match.HomeTeam.Name)" 
                                             alt="@match.HomeTeam.Name flag" 
                                             class="rounded shadow-sm me-3" 
                                             style="width: 38px; height: 26px; object-fit: cover; border: 1px solid #eaeaea;"/>
                                        <span class="fw-semibold text-dark fs-5">@match.HomeTeam.Name</span>
                                    </div>
                                    <span class="score-box fs-5 px-2 py-1">
                                        @(match.HomeScore.HasValue ? match.HomeScore.ToString() : "-")
                                    </span>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center my-2">
                                    <div class="d-flex align-items-center">
                                        <img src="@GetFlagUrl(match.AwayTeam.Name)" 
                                             alt="@match.AwayTeam.Name flag" 
                                             class="rounded shadow-sm me-3" 
                                             style="width: 38px; height: 26px; object-fit: cover; border: 1px solid #eaeaea;"/>
                                        <span class="fw-semibold text-dark fs-5">@match.AwayTeam.Name</span>
                                    </div>
                                    <span class="score-box fs-5 px-2 py-1">
                                        @(match.AwayScore.HasValue ? match.AwayScore.ToString() : "-")
                                    </span>
                                </div>

                            </div>
                            
                            <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center px-3 pb-3 pt-0 small">
                                <span class="text-muted text-truncate me-2" title="@match.Stadium.Name (@match.Stadium.City, @match.Stadium.Country)">
                                    📍 @match.Stadium.Name - @match.Stadium.City
                                </span>
                                <span class="badge px-2 py-1 @(match.Status == "Finished" ? "bg-success" : "bg-light text-dark border")">
                                    @match.Status
                                </span>
                            </div>

                        </div>
                    </div>
                }
            </div>
        }
    }
</div>