@{
    Layout = null;
    ViewData["Title"] = "Sign In - WorldCup2026";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/matches.css" asp-append-version="true" />
    <style>
        .auth-wrapper {
            min-height: calc(100vh - 120px);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 5;
        }
        .auth-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid #eaeaea;
            width: 100%;
            max-width: 420px;
        }
        .form-control {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 0.75rem 1rem;
            transition: all 0.2s ease;
        }
        .form-control:focus {
            background-color: #ffffff;
            border-color: #0052B4;
            box-shadow: 0 0 0 3px rgba(0, 82, 180, 0.1);
        }
        .btn-auth {
            background: linear-gradient(135deg, #0052B4, #11141a);
            border: none;
            padding: 0.75rem 1rem;
            font-family: 'MyCustomFont', sans-serif;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: transform 0.2s ease;
        }
        .btn-auth:hover {
            transform: translateY(-2px);
            opacity: 0.95;
        }
    </style>
</head>
<body>

<div class="bg-shape-3"></div>
<div class="bg-shape-4"></div>
<div class="bg-shape-5"></div>

<nav class="navbar navbar-expand-lg navbar-dark mb-4">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-inline-flex align-items-center gap-2" href="/">
            <img src="~/WCIcon.svg" alt="World Cup Icon" />
            <span>WorldCup2026</span>
        </a>
    </div>
</nav>

<div class="container auth-wrapper">
    <div class="card auth-card shadow-lg rounded-4 p-4 p-sm-5">
        <h2 class="text-center fw-bold page-title mb-4">Sign In</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 small">
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label small fw-semibold text-muted text-uppercase">Username</label>
                <input type="text" name="username" class="form-control rounded-3" required autocomplete="username" />
            </div>

            <div class="mb-4">
                <label class="form-label small fw-semibold text-muted text-uppercase">Password</label>
                <input type="password" name="password" class="form-control rounded-3" required autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary btn-auth w-100 rounded-3 mb-3">Login</button>

            <div class="text-center small text-muted">
                Don't have an account? <a asp-action="Register" class="fw-semibold text-decoration-none" style="color: #0052B4;">Sign Up</a>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>