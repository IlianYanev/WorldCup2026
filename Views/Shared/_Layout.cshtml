<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorldCup2026</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/matches.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>

<div class="bg-shape-3"></div>
<div class="bg-shape-4"></div>
<div class="bg-shape-5"></div>

<nav class="navbar navbar-expand-lg navbar-dark mb-4">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-inline-flex align-items-center gap-2" href="/">
            <img src="~/WCIcon.svg" alt="World Cup Icon" />
            <span>WorldCup2026</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-link-item">
                    <a class="nav-link" asp-controller="Matches" asp-action="Index">Matches</a>
                </li>
                <li class="nav-link-item">
                    <a class="nav-link" asp-controller="Standings" asp-action="Index">Standings</a>
                </li>
                @if (User.Identity.IsAuthenticated)
                {
                <li class="nav-item">
                     <a class="nav-link" asp-controller="Predictor" asp-action="Index">Предиктор</a>
                </li>
                }
            </ul>
            <div class="d-flex align-items-center gap-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="text-white fw-semibold">👋 Welcome, @User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-sm btn-outline-danger px-3">Logout</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-light px-3">Sign In</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-sm btn-primary px-3" style="background-color: #0052B4; border-color: #0052B4;">Register</a>
                }
            </div>
        </div>
    </div>
</nav>

@RenderBody()

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>